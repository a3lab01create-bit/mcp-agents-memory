{
  "name": "mcp-agents-memory",
  "version": "0.8.1",
  "description": "Long-term memory for AI agents with provenance tracking",
  "main": "build/index.js",
  "type": "module",
  "bin": {
    "mcp-agents-memory": "build/index.js"
  },
  "files": [
    "build",
    ".env.example",
    "README.md",
    "RESPEC.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node build.mjs",
    "prepare": "true",
    "start": "node build/index.js",
    "dev": "ts-node --esm src/index.ts",
    "setup": "npm run build && node build/index.js setup",
    "migrate": "npm run build && node build/index.js migrate",
    "bench:tagger": "npx tsx scripts/ab_tagger.ts"
  },
  "keywords": [
    "mcp",
    "ai",
    "memory",
    "agents",
    "postgresql",
    "pgvector",
    "claude",
    "gemini"
  ],
  "author": "Hoon <isaac@triplealab.com> (triplealab)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/a3lab01create-bit/mcp-agents-memory.git"
  },
  "bugs": {
    "url": "https://github.com/a3lab01create-bit/mcp-agents-memory/issues"
  },
  "homepage": "https://github.com/a3lab01create-bit/mcp-agents-memory#readme",
  "dependencies": {},
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@notionhq/client": "^5.20.0",
    "@tavily/core": "^0.7.2",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.11.24",
    "@types/pg": "^8.11.2",
    "@types/ssh2": "^1.11.16",
    "@types/tunnel-ssh": "^5.0.4",
    "dotenv": "^16.4.5",
    "esbuild": "^0.27.0",
    "exa-js": "^2.12.1",
    "inquirer": "^9.2.16",
    "openai": "^6.34.0",
    "pg": "^8.11.3",
    "ssh2": "^1.15.0",
    "ts-node": "^10.9.2",
    "tunnel-ssh": "^5.2.0",
    "typescript": "^5.3.3",
    "zod": "^3.22.4"
  }
}

# Database Settings
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=password
DB_NAME=mcp_memory

# SSH Tunneling (Optional - Set SSH_ENABLED=true to use)
SSH_ENABLED=false
SSH_HOST=
SSH_PORT=22
SSH_USER=
SSH_KEY_PATH=

# OpenAI (Required for semantic search + Librarian AI)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Librarian AI Model (for automatic fact extraction)
# Default: gpt-4o-mini (fast & cheap, $0.15/1M tokens)
# Options: gpt-4o-mini, gpt-4o, gpt-4.1-mini
LIBRARIAN_MODEL=gpt-4o-mini
MEMORY_DEFAULT_SUBJECT=user_hoon # Optional: Default subject key (e.g., your name)

# Skill Promotion Engine (background auto-curator)
# Default: disabled (opt-in). When enabled, runs Curator + Auditor on schedule.
PROMOTION_ENABLED=false
PROMOTION_INTERVAL_MIN=60
PROMOTION_WARMUP_MIN=5

# Memory Auditor (v5.0 SYNC external knowledge grounding)
# When enabled, high-importance learning facts get reconciled against Tavily/Exa sources
# BEFORE save. Adds 5-15s latency per qualifying fact + auditor model cost. Default off.
# Gate: MEMORY_AUDIT_ENABLED=true AND fact_type='learning' AND importance > 7.
MEMORY_AUDIT_ENABLED=false
MEMORY_AUDITOR_MODEL=claude-sonnet-4-6

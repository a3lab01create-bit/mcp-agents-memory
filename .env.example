# Database Settings
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=password
DB_NAME=mcp_memory

# SSH Tunneling (Optional - Set SSH_ENABLED=true to use)
SSH_ENABLED=false
SSH_HOST=
SSH_PORT=22
SSH_USER=
SSH_KEY_PATH=

# OpenAI (Required for semantic search + Librarian AI)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Librarian AI Model (for automatic fact extraction)
# Default: gpt-4o-mini (fast & cheap, $0.15/1M tokens)
# Options: gpt-4o-mini, gpt-4o, gpt-4.1-mini
LIBRARIAN_MODEL=gpt-4o-mini
